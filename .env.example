# =============================================================================
# Kaal Bhairav OSINT Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in any keys you have.
# ALL external API keys are optional. If a key is missing, that provider is
# silently skipped at startup and excluded from search results.
# Never commit real credentials to source control.
# =============================================================================

# --- Internal Service URLs ---------------------------------------------------
# These are pre-configured for Docker Compose. Only change if using custom infra.

# Go asset-service URL (called by Next.js search route)
GO_SERVICE_URL=http://localhost:50051

# web-check-api internal URL (only reachable inside the Docker network)
WEBCHECK_API_URL=http://kb-webcheck:8080

# Redis connection string used by asset-service
REDIS_URL=redis://kb-redis:6379

# MongoDB connection string used by Next.js
MONGODB_URI=mongodb://localhost:27017/osint

# JWT secret for session signing (required, set a strong random string)
JWT_SECRET=change_me_to_a_long_random_string

# --- Optional External OSINT API Keys ----------------------------------------
# Sign up at each provider's site to get free-tier keys.

# Shodan (https://account.shodan.io/) — used for IP-based port/banner lookups
SHODAN_API_KEY=

# VirusTotal (https://www.virustotal.com/gui/my-apikey) — domain & IP reputation
VT_API_KEY=

# AbuseIPDB (https://www.abuseipdb.com/api) — IP abuse confidence scoring
ABUSEIPDB_API_KEY=

# AlienVault OTX (https://otx.alienvault.com/api) — threat intelligence pulses
OTX_API_KEY=

# NVD / NIST CVE API (https://nvd.nist.gov/developers/request-an-api-key)
# Optional — increases rate limit from 5 req/30s to 50 req/30s
NVD_API_KEY=
